<%- include('partials/header') %>

<section class="page-hero">
  <div class="container">
    <h1>Our Wildlife Habitats</h1>
    <p>Discover four incredible themed worlds, each home to amazing animals and experiences</p>
  </div>
</section>

<section class="habitats-list">
  <div class="container">
    <div class="habitat-grid">
      <% habitats.forEach(habitat => { %>
      <div class="habitat-card">
        <img src="/images/<%= habitat.image %>" alt="<%= habitat.name %>" />
        <div class="card-body">
          <h3><%= habitat.name %></h3>
          <p><%= habitat.description %></p>
          <a href="/habitats/<%= habitat.id %>" class="btn">Explore</a>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<%- include('partials/footer') %>